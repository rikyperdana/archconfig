#!/bin/bash
# Location: ~/.local/bin/

help() {
  cat << 'EOF'
  Usage:
    yt mus <url> # for downloading mp3
    yt vid <url> # for downloading mp4
    yt save <search phrase> # for tui yt download
    yt stream <search phrase> # for tui yt stream
EOF
}

mus() {
  yt-dlp --embed-chapters -x --audio-format mp3 $1
}

vid() {
  yt-dlp -f 'worstvideo+worstaudio/worst' $1
}

save() {
  yt-dlp "ytsearch25:$1" --flat-playlist \
    --print "%(title)s  [%(uploader)s]  (%(duration_string)s)  %(id)s" | \
    fzf --with-nth=1..-2 | awk '{print $NF}' | xargs -I {} yt-dlp -f \
    "bestvideo[height<=?480]+bestaudio/best[height<=?480]/best" \
    "https://youtu.be/{}"
}

stream() {
  local results
  results=$(yt-dlp "ytsearch25:$1" --flat-playlist \
    --print "%(title)s  [%(uploader)s]  (%(duration_string)s)  %(id)s")
  while true; do
    local selection
    selection=$(echo "$results" | fzf --with-nth=1..-2 \
      --header "Select a video (ESC to quit):")
    [[ -z "$selection" ]] && break
    local video_id
    video_id=$(echo "$selection" | awk '{print $NF}')
    local video_url="https://youtu.be/$video_id"
    echo "Playing: $(echo "$selection" | sed 's/ [^ ]*$//')"
    mpv --quiet --ytdl-format="[height<=?480]" "$video_url" > /dev/null 2>&1
    echo "$video_url" | xclip -selection clipboard
    # feel free to yt-dlp pasted_url
  done
}

"$@"